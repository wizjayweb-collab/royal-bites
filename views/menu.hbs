<section class="page-hero">
  <div class="page-hero-content">
    <p class="section-eyebrow">✦ Explore Our Menu</p>
    <h1>Our Royal Menu</h1>
    <p>Every dish crafted with passion, served with elegance</p>
  </div>
</section>

<section class="menu-section section">
  <div class="container">
    <div class="menu-tabs">
      <button class="tab-btn active" onclick="filterMenu('all',this)">All</button>
      <button class="tab-btn" onclick="filterMenu('starters',this)">🥗 Starters</button>
      <button class="tab-btn" onclick="filterMenu('mains',this)">🍽️ Mains</button>
      <button class="tab-btn" onclick="filterMenu('seafood',this)">🐟 Seafood</button>
      <button class="tab-btn" onclick="filterMenu('desserts',this)">🍰 Desserts</button>
      <button class="tab-btn" onclick="filterMenu('drinks',this)">🍹 Drinks</button>
    </div>

    <div class="menu-grid" id="menuGrid">
      {{#each items}}
      <div class="menu-item" data-cat="{{this.category}}">
        <div class="menu-item-media">
          {{#if this.image_data}}
            <img src="{{this.image_data}}" alt="{{this.name}}">
          {{else}}
            <span class="menu-item-emoji">{{this.emoji}}</span>
          {{/if}}
        </div>
        <div class="menu-item-info">
          {{#if this.tag}}<div class="menu-tag">{{this.tag}}</div>{{/if}}
          <div class="menu-item-header">
            <h3>{{this.name}}</h3>
            <span class="menu-price">{{this.price}}</span>
          </div>
          <p>{{this.description}}</p>
          <a href="/reservations" class="menu-order-btn">Order Now →</a>
        </div>
      </div>
      {{/each}}
    </div>

    {{#unless items}}
    <div style="text-align:center;padding:80px;color:#999">
      <div style="font-size:4rem;margin-bottom:16px">🍽️</div>
      <p>Menu coming soon!</p>
    </div>
    {{/unless}}
  </div>
</section>
