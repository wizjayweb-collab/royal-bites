<div class="page-header">
  <h1>📩 Messages</h1>
  <p>Messages from your website contact form</p>
</div>
<div class="admin-card">
  {{#if messages}}
  <div style="display:flex;flex-direction:column;gap:16px">
    {{#each messages}}
    <div style="background:rgba(255,255,255,0.03);border:1px solid #333;border-radius:12px;padding:20px">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:12px">
        <div>
          <strong style="color:white">{{this.name}}</strong>
          <span style="color:#888;font-size:0.82rem;margin-left:8px">{{this.email}}</span>
          {{#if this.subject}}<div style="font-size:0.88rem;color:var(--gold);margin-top:4px">Re: {{this.subject}}</div>{{/if}}
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <small style="color:#666">{{this.created_at}}</small>
          <form action="/admin/messages/{{this.id}}/delete" method="POST" onsubmit="return confirm('Delete?')" style="margin:0">
            <button type="submit" class="btn-sm btn-danger">🗑️</button>
          </form>
        </div>
      </div>
      <p style="color:#ccc;font-size:0.9rem;line-height:1.7">{{this.message}}</p>
      <a href="mailto:{{this.email}}" class="btn-sm" style="margin-top:12px;display:inline-block">📧 Reply</a>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-state">📩 No messages yet</div>
  {{/if}}
</div>
