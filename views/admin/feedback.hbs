<div class="page-header">
  <h1>⭐ Guest Reviews</h1>
  <p>Approve or delete customer reviews</p>
</div>

{{#if pending}}
<div class="alert alert-warning" style="background:rgba(230,126,34,0.15);color:#e67e22;border:1px solid rgba(230,126,34,0.3);padding:14px 18px;border-radius:10px;margin-bottom:20px">
  ⏳ {{pending}} review(s) waiting for approval
</div>
{{/if}}

<div class="admin-card">
  {{#if feedback}}
  <div style="display:flex;flex-direction:column;gap:16px">
    {{#each feedback}}
    <div style="background:rgba(255,255,255,0.03);border:1px solid {{#if this.approved}}rgba(46,204,113,0.2){{else}}rgba(230,126,34,0.2){{/if}};border-radius:12px;padding:20px">
      <div style="display:flex;justify-content:space-between;align-items:start;flex-wrap:wrap;gap:12px;margin-bottom:12px">
        <div>
          <strong style="color:white;font-size:0.95rem">{{this.name}}</strong>
          {{#if this.email}}<span style="color:#888;font-size:0.82rem;margin-left:8px">{{this.email}}</span>{{/if}}
          <div style="margin-top:4px">
            {{#if (eq this.rating 5)}}⭐⭐⭐⭐⭐{{/if}}
            {{#if (eq this.rating 4)}}⭐⭐⭐⭐{{/if}}
            {{#if (eq this.rating 3)}}⭐⭐⭐{{/if}}
            {{#if (eq this.rating 2)}}⭐⭐{{/if}}
            {{#if (eq this.rating 1)}}⭐{{/if}}
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
          <span style="font-size:0.75rem;padding:4px 12px;border-radius:20px;font-weight:600;
            background:{{#if this.approved}}rgba(46,204,113,0.15){{else}}rgba(230,126,34,0.15){{/if}};
            color:{{#if this.approved}}#2ecc71{{else}}#e67e22{{/if}}">
            {{#if this.approved}}✅ Approved{{else}}⏳ Pending{{/if}}
          </span>
          <small style="color:#666">{{this.created_at}}</small>
        </div>
      </div>
      <p style="color:#ccc;font-size:0.9rem;line-height:1.7;margin-bottom:14px">"{{this.review}}"</p>
      <div style="display:flex;gap:8px">
        {{#unless this.approved}}
        <form action="/admin/feedback/{{this.id}}/approve" method="POST" style="margin:0">
          <button type="submit" class="btn-sm" style="background:rgba(46,204,113,0.15);color:#2ecc71">✅ Approve</button>
        </form>
        {{/unless}}
        <form action="/admin/feedback/{{this.id}}/delete" method="POST" style="margin:0" onsubmit="return confirm('Delete this review?')">
          <button type="submit" class="btn-sm btn-danger">🗑️ Delete</button>
        </form>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-state">⭐ No reviews yet</div>
  {{/if}}
</div>
